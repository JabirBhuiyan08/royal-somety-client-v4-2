// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatar uploads — only the owner
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024  // 2 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Cover photos
    match /covers/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // 5 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Gallery — read by all members, write by admin only
    // (Admin check done server-side via Cloudinary; block direct Firebase Storage writes)
    match /gallery/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Uploads go through backend → Cloudinary
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
