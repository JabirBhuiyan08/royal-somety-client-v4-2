// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Chat Room ────────────────────────────────────────────────────
    // Only authenticated users can read/write chat messages
    match /somity-chat/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow update, delete: if false; // Messages are immutable
    }

     // ── User Presence ─────────────────────────────────────────────────
     match /presence/{userId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.uid == userId;
     }

     // ── Likes ─────────────────────────────────────────────────────────
     match /likes/{likeId} {
       // Any authenticated user can read likes
       allow read: if request.auth != null;
       // Users can create a like if they are authenticated and the like's userId matches their uid
       allow create: if request.auth != null
         && request.resource.data.userId == request.auth.uid
         && request.resource.data.photoId is string;
       // Users can delete only their own like
       allow delete: if request.auth != null
         && resource.data.userId == request.auth.uid;
       // Updates not allowed (likes are immutable, delete+create instead)
       allow update: if false;
     }

     // ── Deny everything else ─────────────────────────────────────────
     match /{document=**} {
       allow read, write: if false;
     }
  }
}
